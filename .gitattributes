###############################################################################
# Force all text files to use LF
###############################################################################
* text=auto eol=lf

###############################################################################
# Vulkan / Shader binaries
###############################################################################
*.spv binary

###############################################################################
# Windows batch scripts
###############################################################################
*.bat text eol=crlf
*.cmd text eol=crlf

# Exclude dirs from githug language statis
External/* linguist-vendored=true